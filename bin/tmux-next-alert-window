#!/bin/bash
#
# Switch to the next window with a bell alert, cycling across
# all sessions.  If there are no alerts, fall back to cycling
# through opencode windows (names ending in ": oc").  If neither
# exist, display a message.
#
# Usage: tmux-next-alert-window [prev]
#   With "prev" argument, cycle in reverse order.

direction="${1:-next}"

# Get current session:window
current=$(tmux display-message -p '#{session_name}:#{window_index}')

# List all windows with bell flag set, in session:window order.
alert_windows=()
while IFS= read -r line; do
    flag="${line%% *}"
    target="${line#* }"
    if [[ "$flag" == "1" ]]; then
        alert_windows+=("$target")
    fi
done < <(tmux list-windows -a -F '#{window_bell_flag} #{session_name}:#{window_index}')

# Fall back to opencode windows if no alerts
if [[ ${#alert_windows[@]} -eq 0 ]]; then
    while IFS= read -r line; do
        target="${line%% *}"
        name="${line#* }"
        if [[ "$name" == *": oc" ]]; then
            alert_windows+=("$target")
        fi
    done < <(tmux list-windows -a -F '#{session_name}:#{window_index} #{window_name}')

    if [[ ${#alert_windows[@]} -eq 0 ]]; then
        tmux display-message "No alert or opencode windows"
        exit 0
    fi
fi

# Find index of current window in the candidate list
current_idx=-1
for i in "${!alert_windows[@]}"; do
    if [[ "${alert_windows[$i]}" == "$current" ]]; then
        current_idx=$i
        break
    fi
done

# Pick the next (or previous) window, wrapping around
count=${#alert_windows[@]}
if [[ "$direction" == "prev" ]]; then
    if [[ $current_idx -ge 0 ]]; then
        target_idx=$(( (current_idx - 1 + count) % count ))
    else
        target_idx=$(( count - 1 ))
    fi
else
    if [[ $current_idx -ge 0 ]]; then
        target_idx=$(( (current_idx + 1) % count ))
    else
        target_idx=0
    fi
fi

target="${alert_windows[$target_idx]}"
tmux switch-client -t "$target"
