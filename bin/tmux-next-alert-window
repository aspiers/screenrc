#!/bin/bash
#
# Switch to the next window with a bell alert, cycling across
# all sessions (current session first).  If there are no alerts,
# fall back to opencode windows (names ending in ": oc"), again
# with current session first.  If none exist, display a message.
#
# Usage: tmux-next-alert-window [prev]
#   With "prev" argument, cycle in reverse order.

direction="${1:-next}"

# Get current session:window and session name
current=$(tmux display-message -p '#{session_name}:#{window_index}')
current_session="${current%%:*}"

# Reorder a list of session:window targets so that the current
# session's windows come first, preserving order within each group.
reorder_current_session_first() {
    local local_wins=() other_wins=()
    for w in "$@"; do
        if [[ "${w%%:*}" == "$current_session" ]]; then
            local_wins+=("$w")
        else
            other_wins+=("$w")
        fi
    done
    echo "${local_wins[@]} ${other_wins[@]}"
}

# List all windows with bell flag set, in session:window order.
raw_alerts=()
while IFS= read -r line; do
    flag="${line%% *}"
    target="${line#* }"
    if [[ "$flag" == "1" ]]; then
        raw_alerts+=("$target")
    fi
done < <(tmux list-windows -a -F '#{window_bell_flag} #{session_name}:#{window_index}')

# Prioritise current session's windows
read -ra alert_windows <<< "$(reorder_current_session_first "${raw_alerts[@]}")"
# Strip empty element if raw_alerts was empty
[[ "${alert_windows[0]}" == "" ]] && alert_windows=()

# Fall back to opencode windows if no alerts,
# with current session's windows first.
if [[ ${#alert_windows[@]} -eq 0 ]]; then
    raw_oc=()
    while IFS= read -r line; do
        target="${line%% *}"
        name="${line#* }"
        if [[ "$name" == *": oc" ]]; then
            raw_oc+=("$target")
        fi
    done < <(tmux list-windows -a -F '#{session_name}:#{window_index} #{window_name}')

    read -ra alert_windows <<< "$(reorder_current_session_first "${raw_oc[@]}")"
    [[ "${alert_windows[0]}" == "" ]] && alert_windows=()

    if [[ ${#alert_windows[@]} -eq 0 ]]; then
        tmux display-message "No alert or opencode windows"
        exit 0
    fi
fi

# Find index of current window in the candidate list
current_idx=-1
for i in "${!alert_windows[@]}"; do
    if [[ "${alert_windows[$i]}" == "$current" ]]; then
        current_idx=$i
        break
    fi
done

# Pick the next (or previous) window, wrapping around
count=${#alert_windows[@]}
if [[ "$direction" == "prev" ]]; then
    if [[ $current_idx -ge 0 ]]; then
        target_idx=$(( (current_idx - 1 + count) % count ))
    else
        target_idx=$(( count - 1 ))
    fi
else
    if [[ $current_idx -ge 0 ]]; then
        target_idx=$(( (current_idx + 1) % count ))
    else
        target_idx=0
    fi
fi

target="${alert_windows[$target_idx]}"
tmux switch-client -t "$target"
